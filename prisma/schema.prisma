generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id                    String           @id @default(cuid())
  name                  String
  slug                  String           @unique
  shortDescription      String?
  description           String?
  priceCents            Int
  compareAtPriceCents   Int?
  stock                 Int              @default(0)
  status                ProductStatus    @default(DRAFT)
  condition             ProductCondition @default(USED)
  voltage               String?
  warrantyDays          Int?
  brand                 String?
  model                 String?
  algorithm             String?
  hashrate              String?
  consumption           String?
  efficiency            String?
  dailyRevenueText      String?
  monthlyRevenueText    String?
  roiText               String?
  isFeatured            Boolean          @default(false)
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  images                ProductImage[]
  orderItems            OrderItem[]

  @@index([status])
  @@index([brand])
  @@index([isFeatured])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  url       String
  alt       String?
  position  Int     @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String
  document  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders    Order[]

  @@index([email])
  @@index([phone])
  @@index([document])
}

model Order {
  id                    String        @id @default(cuid())
  orderNumber           String        @unique
  customerId            String
  status                OrderStatus   @default(PENDING)
  paymentStatus         PaymentStatus @default(WAITING_PAYMENT)
  subtotalCents         Int
  shippingCents         Int           @default(0)
  discountCents         Int           @default(0)
  totalCents            Int
  notes                 String?

  shippingName          String
  shippingPhone         String
  shippingZipCode       String?
  shippingAddress       String?
  shippingNumber        String?
  shippingComplement    String?
  shippingDistrict      String?
  shippingCity          String?
  shippingState         String?

  trackingCode          String?
  internalNotes         String?

  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  paidAt                DateTime?
  shippedAt             DateTime?
  deliveredAt           DateTime?
  cancelledAt           DateTime?

  customer              Customer      @relation(fields: [customerId], references: [id])
  items                 OrderItem[]
  payment               Payment?

  @@index([customerId])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
}

model OrderItem {
  id              String @id @default(cuid())
  orderId         String
  productId       String
  name            String
  slug            String
  quantity        Int
  unitPriceCents  Int
  totalCents      Int

  order           Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product         Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model Payment {
  id                  String          @id @default(cuid())
  orderId             String          @unique
  provider            PaymentProvider @default(UAIPAG)
  providerPaymentId   String?
  providerTxid        String?
  status              PaymentStatus   @default(WAITING_PAYMENT)
  amountCents         Int
  qrCodeImageUrl      String?
  pixCopyPaste        String?
  expiresAt           DateTime?
  paidAt              DateTime?
  rawResponse         Json?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  order               Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  events              PaymentEvent[]

  @@index([providerPaymentId])
  @@index([providerTxid])
  @@index([status])
}

model PaymentEvent {
  id          String          @id @default(cuid())
  paymentId   String?
  provider    PaymentProvider
  eventId      String?
  eventType    String?
  payload      Json
  receivedAt   DateTime        @default(now())
  processedAt  DateTime?
  isProcessed  Boolean         @default(false)

  payment      Payment?        @relation(fields: [paymentId], references: [id])

  @@index([paymentId])
  @@index([eventId])
  @@index([eventType])
  @@index([receivedAt])
}

model AdminUser {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  role         AdminRole @default(ADMIN)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

enum ProductStatus {
  DRAFT
  ACTIVE
  OUT_OF_STOCK
  ARCHIVED
}

enum ProductCondition {
  NEW
  USED
  REFURBISHED
}

enum OrderStatus {
  PENDING
  AWAITING_PAYMENT
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
  MANUAL_REVIEW
}

enum PaymentStatus {
  WAITING_PAYMENT
  PENDING
  PAID
  EXPIRED
  CANCELLED
  FAILED
  REFUNDED
}

enum PaymentProvider {
  UAIPAG
  MANUAL
}

enum AdminRole {
  ADMIN
  OPERATOR
}
